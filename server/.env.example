# ─────────────────────────────────────────────────────────────────────────────
# Popcornn Signaling Server — Environment Configuration Example
# ─────────────────────────────────────────────────────────────────────────────

# The port the signaling server will listen on. (Default: 4000)
PORT=4000

# The allowed CORS origin. Set this to the production Vercel URL
# once the frontend has been deployed. (Default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000
